#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STACKS_DIR="$SCRIPT_DIR/../stacks"
DC="$SCRIPT_DIR/dc"

echo "Stopping homelab..."

find "$STACKS_DIR" -mindepth 2 -maxdepth 2 \
    \( -name "compose.yaml" -o -name "docker-compose.yml" \) |
sort -r |
while read -r compose; do
    stack="$(dirname "$compose")"

    echo "→ $(basename "$stack")"

    (
        cd "$stack"
        "$DC" down
    )
done

echo
echo "Done."